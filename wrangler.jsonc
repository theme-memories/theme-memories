{
  "$schema": "node_modules/wrangler/config-schema.json",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "astro.amia.work",
      "custom_domain": true,
    },
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
    },
  },
  "placement": {
    "mode": "smart",
  },
  "compatibility_date": "2026-02-24",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "name": "theme-memories",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "secrets_store_secrets": [
    {
      "binding": "BETTER_AUTH_SECRET",
      "store_id": "c5b03c1fc22547d0bb1ee70629d4b6dd",
      "secret_name": "BETTER_AUTH_SECRET",
    },
    {
      "binding": "BETTER_AUTH_URL",
      "store_id": "c5b03c1fc22547d0bb1ee70629d4b6dd",
      "secret_name": "BETTER_AUTH_URL",
    },
    {
      "binding": "MONGO_URI",
      "store_id": "c5b03c1fc22547d0bb1ee70629d4b6dd",
      "secret_name": "MONGO_URI",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "ce1380ded3d84dcaa25c359858a77598",
    },
  ],
  "images": {
    "binding": "IMAGES",
  },
}
