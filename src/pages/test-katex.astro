---
export const prerender = false;

import HeadTag from "@component/html/head.astro";
import markdownit from "markdown-it";
import mdKatex from "@vscode/markdown-it-katex";
import katex from "katex";

const md = new markdownit().use(mdKatex, { katex });

const testCases = [
  {
    name: "Problematic Case",
    content: `$$\\sqrt{3x-1}+(1+x)^2$$`,
    description:
      "Testing the reported issue where \\sqrt might be parsed as \\s",
  },
  {
    name: "Simple Square Root",
    content: `$\\sqrt{x}$`,
    description: "Inline square root",
  },
  {
    name: "Complex KaTeX",
    content: `$$\\int_{a}^{b} x^2 dx = \\frac{b^3 - a^3}{3}$$`,
    description: "Standard integral",
  },
  {
    name: "Problematic Case 2",
    content: `$$\sqrt{3x-1}+(1+x)^2$$`,
    description:
      "Testing the reported issue where \\sqrt might be parsed as \\s",
  },
  {
    name: "Simple Square Root 2",
    content: `$\sqrt{x}$`,
    description: "Inline square root",
  },
  {
    name: "Complex KaTeX 2",
    content: `$$\\left( \\sum_{k=1}^n a_k b_k \\right)^2 \\leq \\left( \\sum_{k=1}^n a_k^2 \\right) \\left( \\sum_{k=1}^n b_k^2 \\right)$$`,
    description: "Standard integral",
  },
];

const renderedCases = testCases.map((tc) => ({
  ...tc,
  html: md.render(tc.content),
}));
---

<html lang="en">
  <head>
    <HeadTag title="KaTeX Test Page" />
  </head>
  <body class="bg-slate-50 p-8">
    <main class="mx-auto max-w-4xl space-y-12">
      <h1 class="text-3xl font-bold">KaTeX Rendering Test</h1>

      <div class="grid gap-8">
        {
          renderedCases.map((tc) => (
            <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <h2 class="text-xl font-semibold text-slate-800">{tc.name}</h2>
              <p class="mb-4 text-sm text-slate-500">{tc.description}</p>

              <div class="mb-4">
                <span class="text-xs font-medium text-slate-400 uppercase">
                  Raw Markdown:
                </span>
                <pre class="mt-1 overflow-x-auto rounded bg-slate-100 p-2 font-mono text-sm">
                  {tc.content}
                </pre>
              </div>

              <div>
                <span class="text-xs font-medium text-slate-400 uppercase">
                  Rendered Output:
                </span>
                <div
                  class="prose prose-slate mt-2 max-w-none rounded border bg-white p-4"
                  set:html={tc.html}
                />
              </div>
            </div>
          ))
        }
      </div>
    </main>
  </body>
</html>
