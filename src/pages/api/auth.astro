---
export const prerender = false;

import { getEntry } from "astro:content";
import { z } from "astro/zod";
import { env } from "cloudflare:workers";
import { type verifyTypes, type argon2Types } from "@ctypes/consts";

if (Astro.request.method !== "POST") {
  return Astro.redirect("/404");
}

const formData = await Astro.request.formData();
const data = Object.fromEntries(formData.entries());

const schema = z.object({
  slug: z
    .string()
    .regex(/^[a-z0-9]+(?:-[a-z0-9]+)*$/, "Format error.")
    .min(1, "Slug cannot be empty.")
    .max(32, "Slug cannot exceed 32 characters."),
  answer: z.string().min(1, "Answer is required."),
  "cf-turnstile-response": z.string().min(1, "Captcha is required."),
  sessionId: z.string().min(1, "Session ID is required."),
});

const result = schema.safeParse(data);

if (!result.success) {
  if (!data.slug || data.slug === "") {
    return Astro.redirect("404");
  }
  return Astro.redirect(`/login/${data.slug}`);
}

const {
  slug,
  answer,
  "cf-turnstile-response": turnstileResponse,
  sessionId,
} = result.data;

const desiredId = await Astro.session?.sessionID;
if (sessionId !== desiredId) {
  return Astro.redirect(`/login/${slug}`);
}

const turnstileSecret = await env.TURNSTILE_SECRET.get();

const verifyResponse = await fetch(
  "https://challenges.cloudflare.com/turnstile/v0/siteverify",
  {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      secret: turnstileSecret,
      response: turnstileResponse,
      idempotency_key: sessionId,
    }),
  },
);

const verifyResult: verifyTypes = await verifyResponse.json();

if (!verifyResult.success) {
  return Astro.redirect(`/login/${slug}`);
}

const argon2Url = await env.ARGON2_URL.get();
const sanitizedAnswer = (answer as string)
  .replace(/[^a-zA-Z0-9!@#$%^&*]/g, "")
  .replace(/[Ili0oO]/g, "");

const argon2Response = await fetch(argon2Url, {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
    slug: slug,
    answer: sanitizedAnswer,
  }),
});

const argon2Result: argon2Types = await argon2Response.json();

if (!argon2Result.success) {
  return Astro.redirect(`/login/${slug}`);
}

const post = await getEntry("cpriv", slug);
if (!post || post.data.draft) {
  return Astro.redirect("/404");
}

await Astro.session?.regenerate();
await Astro.session?.set("unlocked", post.id);
return Astro.redirect(`/posts/private/${post.id}`);
---
