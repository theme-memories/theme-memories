---
export const prerender = false;

import { getEntry } from "astro:content";
import { env } from "cloudflare:workers";
import { type verifyTypes, type argon2Types } from "@ctypes/consts";
import nodeCrypto from "node:crypto";

if (Astro.request.method !== "POST") {
  return Astro.redirect("/404");
}

async function hmacCalculate(key: string, message: string): Promise<string> {
  const encoder = new TextEncoder();
  const keyData = encoder.encode(key);
  const messageData = encoder.encode(message);

  const cryptoKey = await nodeCrypto.subtle.importKey(
    "raw",
    keyData,
    { name: "HMAC", hash: "SHA-256" },
    false,
    ["sign"],
  );

  const signature = await nodeCrypto.subtle.sign(
    "HMAC",
    cryptoKey,
    messageData,
  );
  return btoa(String.fromCharCode(...new Uint8Array(signature)));
}

const formData = await Astro.request.formData();
const turnstileResponse = formData.get("cf-turnstile-response") as string;
const slug = formData.get("slug") as string;
const answer = formData.get("answer") as string;

if (!slug || !/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug)) {
  return Astro.redirect("/404");
}

if (!answer || !turnstileResponse) {
  return Astro.redirect(`/login/${slug}`);
}

const sessionId = await Astro.session?.sessionID;
const turnstileSecret = await env.TURNSTILE_SECRET.get();

const verifyResponse = await fetch(
  "https://challenges.cloudflare.com/turnstile/v0/siteverify",
  {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      secret: turnstileSecret,
      response: turnstileResponse,
      idempotency_key: sessionId,
    }),
  },
);

const verifyResult: verifyTypes = await verifyResponse.json();

if (!verifyResult.success) {
  return Astro.redirect(`/login/${slug}`);
}

const argon2Url = await env.ARGON2_URL.get();

if (/[^a-zA-Z0-9!@#$%^&*]/.test(answer)) {
  return Astro.redirect(`/login/${slug}`);
}

const hmacC2V = await env.HMAC_SECRET_C2V.get();
const reqTimestamp = Date.now().toString();
const payload = JSON.stringify({
  slug: slug,
  answer: answer,
  timestamp: reqTimestamp,
});
const payloadHmac = await hmacCalculate(hmacC2V, payload);

const argon2Response = await fetch(argon2Url, {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    "X-Amia-HMAC": payloadHmac,
    "X-Amia-Timestamp": reqTimestamp,
  },
  body: payload,
});

const responseHmac = argon2Response.headers.get("X-Amia-HMAC");

if (!responseHmac) {
  return Astro.redirect(`/login/${slug}`);
}

const responseRaw = await argon2Response.clone().text();
const hmacV2C = await env.HMAC_SECRET_V2C.get();
const expectedHmac = await hmacCalculate(hmacV2C, responseRaw);
const base64ToUint8Array = (base64: string) => {
  const binaryString = atob(base64);
  const bytes = new Uint8Array(binaryString.length);
  for (let i = 0; i < binaryString.length; i++) {
    bytes[i] = binaryString.charCodeAt(i);
  }
  return bytes;
};
const responseHmacUint8 = base64ToUint8Array(responseHmac);
const expectedHmacUint8 = base64ToUint8Array(expectedHmac);

if (
  responseHmacUint8.length !== expectedHmacUint8.length ||
  !nodeCrypto.timingSafeEqual(responseHmacUint8, expectedHmacUint8)
) {
  return Astro.redirect(`/login/${slug}`);
}

const argon2Result: argon2Types = await argon2Response.json();

if (!argon2Result.success) {
  return Astro.redirect(`/login/${slug}`);
}

const post = await getEntry("cpriv", slug);

if (!post || post.data.draft) {
  return Astro.redirect("/404");
}

await Astro.session?.regenerate();
await Astro.session?.set("unlocked", post.id);
return Astro.redirect(`/posts/private/${post.id}`);
---
