---
// Test Argon2id performance on Cloudflare Workers using @awasm/noble
// Parameters from scripts/hashpwd.ts:
// memoryCost: 47104 (46 MiB)
// timeCost: 1
// parallelism: 1
import { argon2id } from "hash-wasm";

export const prerender = false;

let result = "";
let duration = 0;
let error = "";

try {
  const password = "test-password";
  const salt = crypto.getRandomValues(new Uint8Array(16));

  // Latest hash-wasm parameter keys:
  // memorySize: amount of memory in kibibytes
  // iterations: number of iterations
  const memorySize = 47104;
  const iterations = 1;
  const parallelism = 1;

  const start = performance.now();

  // Generate Argon2id hash
  const hash = await argon2id({
    password: password,
    salt: salt,
    parallelism: parallelism,
    iterations: iterations,
    memorySize: memorySize,
    hashLength: 64,
    outputType: "hex", // Directly get hex string
  });

  const end = performance.now();
  duration = end - start;
  result = hash;
} catch (e: any) {
  error = e.message;
}
---

<html>
  <head>
    <title>Argon2id (hash-wasm) Test</title>
  </head>
  <body>
    <h1>Argon2id Performance Test (hash-wasm)</h1>
    <p><strong>Parameters:</strong></p>
    <ul>
      <li>Memory Cost: 47,104 KB (~46 MiB)</li>
      <li>Time Cost (Iterations): 1</li>
      <li>Parallelism: 1</li>
      <li>Salt Length: 16 bytes</li>
    </ul>

    {
      error ? (
        <div style="color: red; border: 1px solid red; padding: 1rem; background: #fff0f0;">
          <strong>Error:</strong> {error}
          <p style="font-size: 0.9rem; margin-top: 0.5rem;">
            Note: If you see "Worker exceeded resource limits", the memory cost
            (m) might be too high for the 128MB limit.
          </p>
        </div>
      ) : (
        <div>
          <p>
            <strong>Duration:</strong> {duration.toFixed(2)} ms
          </p>
          <p>
            <strong>Result (Hash):</strong> <code>{result}</code>
          </p>
          <p>
            <strong>Status:</strong>
            {duration > 10 ? (
              <span style="color: red;">
                Likely to exceed Free Plan CPU limit (10ms)
              </span>
            ) : (
              <span style="color: green;">
                Within Free Plan CPU limit (10ms)
              </span>
            )}
          </p>
        </div>
      )
    }
  </body>
</html>
