---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Weather from "../../components/Weather.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group posts by year and month
const groupedPosts: Record<string, typeof posts> = {};
posts.forEach((post) => {
  const yearMonth = post.data.pubDate.toLocaleDateString("ja-JP-u-ca-japanese", {
    year: "numeric",
    month: "long",
  });
  if (!groupedPosts[yearMonth]) {
    groupedPosts[yearMonth] = [];
  }
  groupedPosts[yearMonth].push(post);
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .timeline {
        width: 960px;
        margin: auto;
        padding: 2rem 0;
      }

      .month-group {
        position: relative;
        padding-left: 120px; /* Space for the sticky date */
      }

      .month-header {
        position: -webkit-sticky; /* For Safari */
        position: sticky;
        top: 2rem; /* Adjust as needed */
        left: 0;
        width: 100px; /* Width of the sticky date */
        font-size: 1.25rem;
        font-weight: bold;
        color: rgb(var(--accent));
        text-align: right;
        padding-right: 20px;
      }

      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .post-item {
        display: flex;
        align-items: baseline;
        padding: 1rem 0;
        border-bottom: 1px solid rgb(var(--gray-light) / 20%);
      }

      .post-date {
        width: 80px;
        text-align: right;
        color: rgb(var(--gray-light));
        font-size: 0.9rem;
        padding-right: 20px;
      }

      .post-title a {
        font-size: 1.1rem;
        color: rgb(var(--gray-light));
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .post-title a:hover {
        color: rgb(var(--accent));
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="timeline">
      {
        Object.entries(groupedPosts).map(([month, posts]) => (
          <div class="month-group">
            <div class="month-header">{month}</div>
            <ul class="post-list">
              {posts.map((post) => (
                <li class="post-item">
                  <div class="post-date">
                    <FormattedDate date={post.data.pubDate} format="day" />
                  </div>
                  <div class="post-title">
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </main>
    <Footer />
    <Weather size="big" />
  </body>
</html>
