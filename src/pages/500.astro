---
export const prerender = true;

import Layout from "@layouts/Posts.astro";
import ErrorImg from "@assets/500.jpg";
---

<Layout
  title="500: Internal Server Error"
  slug="500"
  description="Something went wrong on our end."
  draft={false}
  pubDate={new Date()}
  banner={ErrorImg}
  protected={false}
>
  <p>Oops! It seems something went wrong on our server.</p>
  <p>
    We've been notified and are looking into it. Please try again later, or head
    back to the <a href="/posts">homepage</a>.
  </p>
</Layout>
