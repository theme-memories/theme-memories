---
// Test PBKDF2 performance on Cloudflare Workers
// PBKDF2 parameters from scripts/hashpwd.ts:
// iterations: 100,000
// keylen: 64
// digest: sha512
export const prerender = false;

let result = "";
let duration = 0;
let error = "";

try {
  const password = "test-password";
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const iterations = 100000;
  const keylen = 64 * 8; // bytes to bits
  const digest = "SHA-512";

  const start = globalThis.performance.now();

  // Import the password as a key
  const baseKey = await crypto.subtle.importKey(
    "raw",
    new TextEncoder().encode(password),
    "PBKDF2",
    false,
    ["deriveBits"],
  );

  // Derive the bits using PBKDF2
  const derivedBits = await crypto.subtle.deriveBits(
    {
      name: "PBKDF2",
      salt: salt,
      iterations: iterations,
      hash: digest,
    },
    baseKey,
    keylen,
  );

  const end = globalThis.performance.now();
  duration = end - start;
  result = Array.from(new Uint8Array(derivedBits))
    .map((b) => b.toString(16).padStart(2, "0"))
    .join("");

  // Debugging info
  const debugInfo = `Start: ${start.toFixed(4)}, End: ${end.toFixed(4)}`;
  console.log(`PBKDF2 Debug: ${debugInfo}`);
  // We can store this in a variable to show on page if needed
  (globalThis as any).pbkdf2Debug = debugInfo;
} catch (e: any) {
  error = e.message;
}
---

<html>
  <head>
    <title>PBKDF2 Worker Test</title>
  </head>
  <body>
    <h1>PBKDF2 Performance Test</h1>
    <p><strong>Parameters:</strong></p>
    <ul>
      <li>Iterations: 100,000</li>
      <li>Key Length: 64 bytes</li>
      <li>Digest: SHA-512</li>
    </ul>

    {
      error ? (
        <p style="color: red;">Error: {error}</p>
      ) : (
        <div>
          <p>
            <strong>Duration:</strong> {duration.toFixed(2)} ms
          </p>
          <p>
            <strong>Result (Hash):</strong> <code>{result}</code>
          </p>
          <p>
            <strong>Status:</strong>
            {duration > 10 ? (
              <span style="color: red;">
                Likely to exceed Free Plan CPU limit (10ms)
              </span>
            ) : (
              <span style="color: green;">
                Within Free Plan CPU limit (10ms)
              </span>
            )}
          </p>
        </div>
      )
    }
  </body>
</html>
