---
// Test scrypt performance on Cloudflare Workers using scrypt-js
// scrypt parameters from scripts/hashpwd.ts:
// N: 65536 (2^16)
// r: 8
// p: 2
// dkLen: 64
import * as scrypt from "scrypt-js";

export const prerender = false;

let result = "";
let duration = 0;
let error = "";

try {
  const password = "test-password";
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const N = 32768;
  const r = 8;
  const p = 3;
  const dkLen = 64;

  const start = performance.now();

  // scrypt-js implementation
  // password and salt must be Uint8Array
  const passwordBytes = new TextEncoder().encode(password);
  const derivedKey = await scrypt.scrypt(passwordBytes, salt, N, r, p, dkLen);

  const end = performance.now();
  duration = end - start;
  result = Array.from(derivedKey)
    .map((b) => b.toString(16).padStart(2, "0"))
    .join("");
} catch (e: any) {
  error = e.message;
}
---

<html>
  <head>
    <title>scrypt Worker Test</title>
  </head>
  <body>
    <h1>scrypt Performance Test</h1>
    <p><strong>Parameters:</strong></p>
    <ul>
      <li>N (Cost): 65,536</li>
      <li>r (Block size): 8</li>
      <li>p (Parallelization): 2</li>
      <li>Key Length: 64 bytes</li>
    </ul>

    {
      error ? (
        <p style="color: red;">Error: {error}</p>
      ) : (
        <div>
          <p>
            <strong>Duration:</strong> {duration.toFixed(2)} ms
          </p>
          <p>
            <strong>Result (Hash):</strong> <code>{result}</code>
          </p>
          <p>
            <strong>Status:</strong>
            {duration > 50 ? (
              <span style="color: red;">
                Likely to exceed Unbound CPU limit (50ms)
              </span>
            ) : (
              <span style="color: green;">Within CPU limit</span>
            )}
          </p>
        </div>
      )
    }
  </body>
</html>
