---
export const prerender = false;

import { type CollectionEntry, getEntry, render } from "astro:content";
import BlogPost from "@layouts/Posts.astro";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/404");
}

const normalizedSlug = slug.startsWith("/") ? slug.slice(1) : slug;
const post = await getEntry("cpriv", normalizedSlug);
if (!post || post.data.draft) return Astro.redirect("/404");

let unlocked = await Astro.session?.get("unlocked");
if (Astro.url.searchParams.get("login") === "success" && unlocked !== post.id) {
  for (let i = 0; i < 50; i++) {
    await new Promise((resolve) => setTimeout(resolve, 200));
    unlocked = await Astro.session?.get("unlocked");
    if (unlocked && unlocked === post.id) break;
  }
}

if (!unlocked || unlocked !== post.id) {
  Astro.session?.destroy();
  return Astro.redirect(`/login/${post.id}`);
}

type Props = CollectionEntry<"cpriv">;

const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>
