---
export const prerender = true;
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Weather from "../../components/Weather.astro";

const blogPostsRaw = await getCollection("blog");
const kanteiPostsRaw = await getCollection("kantei");

const blogPosts = blogPostsRaw.map((post) => ({
  ...post,
  collection: "blog",
}));

const kanteiPosts = kanteiPostsRaw.map((post) => ({
  ...post,
  collection: "kantei",
  data: {
    ...post.data,
    title: `401 - Authorization Required`,
  },
}));

const posts = [...blogPosts, ...kanteiPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group posts by month using the Japanese calendar
const groupedPosts = posts.reduce((acc, post) => {
  const pubDate = post.data.pubDate;
  const key = new Intl.DateTimeFormat("ja-JP-u-ca-japanese", {
    era: "long",
    year: "numeric",
    month: "long",
  }).format(pubDate);

  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(post);
  return acc;
}, {});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .timeline {
        width: 1200px;
        margin: auto;
        padding: 2rem 0;
      }

      .month-group {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
      }

      .month-header {
        flex: 0 0 120px;
        position: sticky;
        top: 1rem;
        align-self: flex-start;
        font-size: 1.25rem;
        font-weight: bold;
        color: rgb(var(--accent));
        text-align: right;
      }

      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        flex: 1;
        min-width: 0;
      }

      .post-item {
        display: flex;
        align-items: baseline;
        padding: 1rem 0;
        border-bottom: 1px solid rgb(var(--gray-light) / 20%);
      }

      .post-date {
        width: 80px;
        text-align: right;
        color: rgb(var(--gray-light));
        font-size: 0.9rem;
        padding-right: 20px;
      }

      .post-title a {
        font-size: 1.1rem;
        color: rgb(var(--gray-light));
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .post-title a:hover {
        color: var(--accent);
      }

      .post-title a.kantei-title:hover {
        color: var(--accent-dark);
      }
    </style>
  </head>
  <body>
    <main class="timeline">
      {
        Object.entries(groupedPosts).map(([month, posts]) => (
          <div class="month-group">
            <div class="month-header">{month}</div>
            <ul class="post-list">
              {posts.map((post) => (
                <li class="post-item">
                  <div class="post-date">
                    <FormattedDate date={post.data.pubDate} format="day" />
                  </div>
                  <div class="post-title">
                    <a
                      href={
                        post.collection === "kantei"
                          ? `/post/${post.id}/`
                          : `/posts/${post.id}/`
                      }
                      class:list={[
                        { "kantei-title": post.collection === "kantei" },
                      ]}
                    >
                      {post.data.title}
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </main>
    <Footer />
    <Weather size="big" />
  </body>
</html>
