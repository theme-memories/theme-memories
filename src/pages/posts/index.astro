---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/Base.astro";
import Footer from "@components/html/Footer.astro";
import FormattedDate from "@components/helper/Date.astro";
import { siteConfig } from "@consts";
import Weather from "@components/widget/Weather.astro";

type Post = (CollectionEntry<"cpub"> | CollectionEntry<"cpriv">) & {
  isPublic: boolean;
};

const cpub = await getCollection("cpub", ({ data }) => !data.draft);
const cpriv = await getCollection("cpriv", ({ data }) => !data.draft);
const posts: Post[] = [
  ...cpub.map((p) => ({ ...p, isPublic: true })),
  ...cpriv.map((p) => ({
    ...p,
    isPublic: false,
    data: { ...p.data, title: "This post is locked." },
  })),
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const groupedPosts = posts.reduce<Record<string, Post[]>>((acc, post) => {
  const pubDate = post.data.pubDate;
  const key = new Intl.DateTimeFormat("ja-JP-u-ca-japanese", {
    era: "long",
    year: "numeric",
    month: "long",
  }).format(pubDate);

  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(post);
  return acc;
}, {});
---

<BaseLayout
  title={`Archive - ${siteConfig.title}`}
  description={siteConfig.description}
>
  <main class="timeline">
    {
      Object.entries(groupedPosts).map(([month, posts]) => (
        <div class="month-group">
          <div class="month-header">{month}</div>
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-item">
                <div class="post-date">
                  <FormattedDate date={post.data.pubDate} format="day" />
                </div>
                <div class="post-title">
                  <a href={`/posts/${post.id}`}>{post.data.title}</a>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </main>
  <Footer />
  <Weather size="big" />
</BaseLayout>
