---
interface Props {
  size: "small" | "big";
}

const { size } = Astro.props;
---

<div id="weather-widget" class="weather-widget" data-size={size}>
  <!-- Content will be loaded by client-side script -->
  <p>天気を読み込み中...</p>
</div>

<script>
  import { getWeatherData, updateWeatherWidget } from "../script/weather";

  document.addEventListener("astro:page-load", async () => {
    const widget = document.getElementById("weather-widget");
    const weatherData = await getWeatherData();
    updateWeatherWidget(widget, weatherData);
  });
</script>
