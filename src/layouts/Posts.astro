---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/Base.astro";
import Footer from "@components/html/Footer.astro";
import FormattedDate from "@components/helper/Date.astro";
import Weather from "@components/widget/Weather.astro";

type Props = CollectionEntry<"cpub">["data"];

const { title, description, pubDate, updDate, banner } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main>
    <article class="prose prose-custom">
      <div class="hero-image mb-12">
        {
          banner && (
            <Image
              width={1280}
              height={720}
              src={banner}
              alt={description || title}
              class="h-auto w-full rounded-2xl object-cover shadow-2xl"
            />
          )
        }
      </div>
      <div class="title mb-12 text-center">
        <div class="date text-subtle mb-4 flex flex-col items-center gap-1">
          <FormattedDate date={pubDate} />
          {
            updDate && (
              <div class="last-updated-on">
                最終更新 <FormattedDate date={updDate} />
              </div>
            )
          }
        </div>
        <h1
          class="mb-8 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl"
        >
          {title}
        </h1>
        <hr />
      </div>
      <slot />
    </article>
  </main>
  <Footer />
  <Weather size="small" />
</BaseLayout>
